generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  CENTRE_ADMIN
  SUPER_ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum Programme {
  PITP
  BBSHRRDB
  NFTP
}

enum BatchType {
  REGULAR
  WEEKEND
}

enum AttendStatus {
  PRESENT
  ABSENT
  LATE
}

enum AsmtType {
  WEEKLY_PROJECT
  LAB_ASSIGNMENT
  FINAL_PROJECT
}

enum AsmtStatus {
  PENDING
  SUBMITTED
  GRADED
  LATE
}

enum QzType {
  MCQ
  TRUE_FALSE
  SHORT_ANSWER
}

enum CertStatus {
  NOT_ELIGIBLE
  PENDING_REVIEW
  APPROVED
  REVOKED
}

enum Priority {
  NORMAL
  URGENT
  HOLIDAY
}

enum QuizKind {
  REGULAR
  MONTHLY_TEST
}

enum TestReviewStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum IssueStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  cnic         String?     @unique
  passwordHash String
  role         Role        @default(STUDENT)
  status       Status      @default(PENDING)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  student      Student?
  instructor   Instructor?
}

model Student {
  id            String         @id @default(cuid())
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id])
  fullName      String
  cnic          String         @unique
  dob           DateTime
  gender        String
  mobile        String
  district      String
  qualification String
  photoUrl      String?
  programme     Programme
  batchId       String?
  batch         Batch?         @relation(fields: [batchId], references: [id])
  attendance    Attendance[]
  submissions   Submission[]
  quizAttempts  QuizAttempt[]
  grades        Grade[]
  certificate   Certificate?
  notifications Notification[]
  testIssues    TestIssue[]
  createdAt     DateTime       @default(now())
}

model Instructor {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id])
  fullName       String
  mobile         String
  specialization String
  photoUrl       String?
  batches        Batch[]
  attendance     Attendance[]     @relation("MarkedBy")
  materials      CourseMaterial[]
  assignments    Assignment[]
  quizzes        Quiz[]
  announcements  Announcement[]
  createdAt      DateTime         @default(now())
}

model Centre {
  id        String   @id @default(cuid())
  name      String
  district  String
  address   String
  capacity  Int
  batches   Batch[]
  createdAt DateTime @default(now())
}

model Batch {
  id            String           @id @default(cuid())
  batchNumber   String
  programme     Programme
  course        String
  batchType     BatchType        @default(REGULAR)
  startDate     DateTime
  endDate       DateTime
  centreId      String
  centre        Centre           @relation(fields: [centreId], references: [id])
  instructorId  String
  instructor    Instructor       @relation(fields: [instructorId], references: [id])
  students      Student[]
  materials     CourseMaterial[]
  assignments   Assignment[]
  quizzes       Quiz[]
  announcements Announcement[]
  schedule      ClassSession[]
  createdAt     DateTime         @default(now())
}

model Attendance {
  id         String       @id @default(cuid())
  studentId  String
  student    Student      @relation(fields: [studentId], references: [id])
  batchId    String
  date       DateTime
  status     AttendStatus
  timeIn     String?
  timeOut    String?
  topic      String?
  markedById String
  markedBy   Instructor   @relation("MarkedBy", fields: [markedById], references: [id])
  createdAt  DateTime     @default(now())

  @@unique([studentId, date])
}

model CourseMaterial {
  id          String     @id @default(cuid())
  batchId     String
  batch       Batch      @relation(fields: [batchId], references: [id])
  instructorId String
  instructor  Instructor @relation(fields: [instructorId], references: [id])
  week        Int
  day         Int?
  title       String
  description String?
  fileUrl     String?
  fileType    String?
  externalUrl String?
  visibleFrom DateTime   @default(now())
  createdAt   DateTime   @default(now())
}

model Assignment {
  id            String       @id @default(cuid())
  batchId       String
  batch         Batch        @relation(fields: [batchId], references: [id])
  instructorId  String
  instructor    Instructor   @relation(fields: [instructorId], references: [id])
  title         String
  description   String
  type          AsmtType
  maxMarks      Int
  weightage     Float
  dueDate       DateTime
  attachmentUrl String?
  allowLate     Boolean      @default(true)
  submissions   Submission[]
  createdAt     DateTime     @default(now())
}

model Submission {
  id            String     @id @default(cuid())
  assignmentId  String
  assignment    Assignment @relation(fields: [assignmentId], references: [id])
  studentId     String
  student       Student    @relation(fields: [studentId], references: [id])
  fileUrl       String?
  note          String?
  status        AsmtStatus @default(SUBMITTED)
  marksObtained Float?
  feedback      String?
  submittedAt   DateTime   @default(now())
  gradedAt      DateTime?

  @@unique([assignmentId, studentId])
}

model Quiz {
  id           String        @id @default(cuid())
  batchId      String
  batch        Batch         @relation(fields: [batchId], references: [id])
  instructorId String
  instructor   Instructor    @relation(fields: [instructorId], references: [id])
  title        String
  instructions String?
  duration     Int
  totalMarks   Int
  weightage    Float
  shuffleQ     Boolean       @default(true)
  shuffleOpts  Boolean       @default(true)
  maxAttempts  Int           @default(1)
  startAt      DateTime
  endAt        DateTime
  published    Boolean       @default(false)
  questions    Question[]
  attempts     QuizAttempt[]
  createdAt    DateTime      @default(now())

  quizKind            QuizKind         @default(REGULAR)
  topicBrief          String?
  aiGenerated         Boolean          @default(false)
  reviewStatus        TestReviewStatus @default(DRAFT)
  questionsPerStudent Int?
  difficultyMix       Json?
  lockdown            Boolean          @default(false)
  issues              TestIssue[]
}

model Question {
  id            String   @id @default(cuid())
  quizId        String
  quiz          Quiz     @relation(fields: [quizId], references: [id])
  type          QzType
  text          String
  options       Json?
  correctAnswer String?
  explanation   String?
  marks         Int      @default(1)
  order         Int
  answers       Answer[]

  difficulty Difficulty @default(MEDIUM)
  approved   Boolean    @default(true)
}

model QuizAttempt {
  id            String    @id @default(cuid())
  quizId        String
  quiz          Quiz      @relation(fields: [quizId], references: [id])
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id])
  startedAt     DateTime  @default(now())
  submittedAt   DateTime?
  timeTaken     Int?
  marksObtained Float?
  answers       Answer[]

  assignedQuestionIds Json?
  violationCount      Int     @default(0)
  flaggedForReview    Boolean @default(false)
  invalidated         Boolean @default(false)
  issues              TestIssue[]
}

model Answer {
  id           String      @id @default(cuid())
  attemptId    String
  attempt      QuizAttempt @relation(fields: [attemptId], references: [id])
  questionId   String
  question     Question    @relation(fields: [questionId], references: [id])
  selectedOpts Json?
  textAnswer   String?
  isCorrect    Boolean?
  marksAwarded Float?
}

model Grade {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id])
  batchId      String
  quizTotal    Float    @default(0)
  assignTotal  Float    @default(0)
  projectTotal Float    @default(0)
  totalScore   Float    @default(0)
  isPassing    Boolean  @default(false)
  updatedAt    DateTime @updatedAt

  @@unique([studentId, batchId])
}

model Certificate {
  id            String     @id @default(cuid())
  studentId     String     @unique
  student       Student    @relation(fields: [studentId], references: [id])
  certificateId String     @unique @default(cuid())
  status        CertStatus @default(NOT_ELIGIBLE)
  issuedAt      DateTime?
  revokedAt     DateTime?
  revokeReason  String?
  pdfUrl        String?
  createdAt     DateTime   @default(now())
}

model ClassSession {
  id           String   @id @default(cuid())
  batchId      String
  batch        Batch    @relation(fields: [batchId], references: [id])
  date         DateTime
  startTime    String
  endTime      String
  topic        String
  sessionType  String
  isCancelled  Boolean  @default(false)
  cancelReason String?
  createdAt    DateTime @default(now())
}

model Announcement {
  id           String     @id @default(cuid())
  batchId      String
  batch        Batch      @relation(fields: [batchId], references: [id])
  instructorId String
  instructor   Instructor @relation(fields: [instructorId], references: [id])
  title        String
  body         String
  priority     Priority   @default(NORMAL)
  createdAt    DateTime   @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String
  createdAt DateTime @default(now())
}

model TestIssue {
  id           String       @id @default(cuid())
  quizId       String
  quiz         Quiz         @relation(fields: [quizId], references: [id])
  attemptId    String?
  attempt      QuizAttempt? @relation(fields: [attemptId], references: [id])
  studentId    String
  student      Student      @relation(fields: [studentId], references: [id])
  reason       String
  status       IssueStatus  @default(PENDING)
  resolvedById String?
  adminNote    String?
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
}
